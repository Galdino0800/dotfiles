#!/usr/bin/env bash

# LocalizaГ§ГЈo baseada no seu contexto atual
LOCATION="Juazeiro+do+Norte"

# Busca apenas o essencial: CondiГ§ГЈo e Temperatura
# %c (Гӯcone original) %t (temperatura)
DATA=$(curl -s "wttr.in/${LOCATION}?format=%c+%t" | tr -d '+')

if [[ -z "$DATA" ]]; then
    echo "IndisponГӯvel"
    exit 1
fi

# Mapeamento de Гӯcones para a sua JetBrainsMono Nerd Font
# Substitui os emojis do wttr pelos Гӯcones que vocГӘ gosta
ICON=$(echo "$DATA" | awk '{print $1}')
TEMP=$(echo "$DATA" | awk '{print $2}')

case $ICON in
    "вҳҖпёҸ"|"у°–ҷ") ICON="пҶ…" ;;
    "вҳҒпёҸ"|"у°–җ") ICON="пғӮ" ;;
    "вӣ…"|"у°–•") ICON="у°–•" ;;
    "рҹҢ§пёҸ"|"у°–—") ICON="пғ©" ;;
    "вӣҲпёҸ"|"у°–“") ICON="у°–“" ;;
    "рҹҢЁпёҸ"|"у°ј¶") ICON="пӢң" ;;
    *) ICON="пғӮ" ;; # ГҚcone padrГЈo caso nГЈo reconheГ§a
esac

echo "$ICON $TEMP"