[global]
    ### EXIBIÇÃO ###
    monitor = 0
    follow = mouse
    font = JetBrains Mono 10
    markup = yes
    format = "\n<b>%s</b>\n%b"
    alignment = center
    
  ### GEOMETRIA ###
    # Reduzido de 380 para 300 para ficar mais compacto
    width = 300
    
    # Altura um pouco menor para acompanhar a largura
    height = (130, 130)
    
    # Mantendo a posição
    offset = (10, 50)
    origin = top-right
    
    # Reduzi um pouco os paddings para não sobrar muito espaço vazio
    padding = 12
    horizontal_padding = 12
    corner_radius = 10

    ### ÍCONES ###
    icon_position = left
    # Mantive 80 para a imagem não perder o detalhe
    max_icon_size = 80
    min_icon_size = 80
    
    ### INTERAÇÃO ###
    mouse_left_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#2E3440"
    foreground = "#ECEFF4"
    timeout = 5

[urgency_normal]
    background = "#2E3440"
    foreground = "#ECEFF4"
    timeout = 8

[urgency_critical]
    background = "#2E3440"
    foreground = "#ECEFF4"
    frame_color = "#BF616A"
    timeout = 0