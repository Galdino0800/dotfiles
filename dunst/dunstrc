[global]
    ### EXIBIÇÃO E FONTE ###
    font = JetBrains Mono 9
    markup = yes
    # Removemos o \n extra para o texto subir um pouco, já que a caixa está menor
    format = "<b>%s</b>\n%b"
    alignment = center
    
    ### GEOMETRIA E POSIÇÃO ###
    # Largura reduzida para ser mais discreta
    width = 280
    # Altura dinâmica: mínima 0, máxima 100
    height = (0, 100)
    
    offset = (15, 60)
    origin = top-right
    
    # Menos espaçamento interno para economizar espaço
    padding = 10
    horizontal_padding = 12
    corner_radius = 8

    ### ASPECTO VISUAL ###
    frame_width = 2
    frame_color = "#81a1c1"

    ### ÍCONES (Versão Mini) ###
    icon_position = left
    # Reduzido de 80 para 64 (tamanho clássico)
    max_icon_size = 64
    min_icon_size = 64
    
    icon_path = /usr/share/icons/Papirus/48x48/status/:/usr/share/icons/Papirus/48x48/devices/:/usr/share/icons/Papirus/48x48/apps/

[urgency_low]
    background = "#2E3440"
    foreground = "#ECEFF4"
    timeout = 4

[urgency_normal]
    background = "#2E3440"
    foreground = "#ECEFF4"
    timeout = 6

[urgency_critical]
    background = "#2E3440"
    foreground = "#ECEFF4"
    frame_color = "#BF616A"
    timeout = 0