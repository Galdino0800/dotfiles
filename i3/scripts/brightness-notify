#!/bin/bash

# 1. Pega o brilho (Garante que seja apenas o número)
BRIGHTNESS=$(brightnessctl -m | cut -d, -f4 | tr -d '%')
[ -z "$BRIGHTNESS" ] && BRIGHTNESS=0

# 2. Configuração da Barra (10 blocos)
# Usamos uma string de referência em vez de comandos complexos de printf
full="▮▮▮▮▮▮▮▮▮▮"
empty="▯▯▯▯▯▯▯▯▯▯"

# Calcula quantos blocos preenchidos (0 a 10)
num=$(( BRIGHTNESS / 10 ))

# Monta a barra cortando as strings acima
BARS="${full:0:num}${empty:0:10-num}"

# 3. Ícone Dinâmico
if [ "$BRIGHTNESS" -le 30 ]; then ICON="󰃞";
elif [ "$BRIGHTNESS" -le 70 ]; then ICON="󰃟";
else ICON="󰃠 "; fi

# 4. Envia a notificação (ID 994)
# Removi qualquer comando que possa imprimir lixo no terminal
notify-send -r 994 -t 1000 -a "Sistema" "$ICON  $BARS  $BRIGHTNESS%"