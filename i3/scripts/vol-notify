#!/bin/bash

# 1. Pega as informações do ALSA em uma única chamada para ser mais rápido
AMIXER=$(amixer sget Master)
VOLUME=$(echo "$AMIXER" | grep -Po '[0-9]+(?=%)' | head -n 1)
MUTE=$(echo "$AMIXER" | grep -q "\[off\]" && echo "yes" || echo "no")

# 2. Configuração da barra (20 blocos)
BARS_N=$(( VOLUME / 5 ))
SPACES_N=$(( 20 - BARS_N ))

# Criando a barra de forma mais eficiente (sem loops complexos)
BARS=$(printf "▮%.0s" $(seq 1 $BARS_N))
SPACES=$(printf "▯%.0s" $(seq 1 $SPACES_N))

# 3. Identificador único para a notificação (evita pilhas de pop-ups)
ID=995

if [ "$MUTE" = "yes" ]; then
    notify-send -r $ID -t 1500 -a "Volume" "󰝟 Mute"
else
    # Escolhe o ícone baseado no nível
    if [ "$VOLUME" -le 30 ]; then ICON="󰕿";
    elif [ "$VOLUME" -le 70 ]; then ICON="󰖀";
    else ICON="󰕾"; fi

    # Envia a notificação substituindo a anterior instantaneamente
    notify-send -r $ID -t 1500 -a "Volume" "$ICON  <b>${BARS}${SPACES}</b>" "Volume: ${VOLUME}%"
fi

# 4. Força a Polybar a atualizar o módulo de volume na hora
pkill -USR1 polybar